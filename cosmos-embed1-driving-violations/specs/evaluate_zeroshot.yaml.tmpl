# NOTE: the container's topk_classification callback is SINGLE-LABEL — for this
# multi-label task its numbers are indicative only. Authoritative metrics come
# from 10_infer_chunks.py + 12/13 (custom path). This spec exists for a quick
# sanity check on the chunk dataset.
results_dir: /results

evaluate:
  checkpoint: null
  load_dataset_pkl: null
  save_dataset_pkl: /results/evaluate_zeroshot/test_embeddings.pkl
  num_gpus: 1
  callbacks:
    topk_classification: true
    embedding_visualization: false
    top_k_values: [1, 3, 5]
    max_eval_samples: 20000

model:
  pretrained_model_path: /model/Cosmos-Embed1-224p
  precision: bf16
  fsdp_shard_size: 1
  input_hw: [224, 224]
  network:
    embed_dim: 256
    num_query_tokens: 32
    max_txt_len: 128
    num_video_frames: 8
    spatial_resolution: [224, 224]
    temporal_encoding_type: neighboring_token_propagation
    contrastive_type: clip
    qformer_pretrain_ckpt: null
    query_pooling_type: avg
    pretrained_text_encoder: false
    pretrained_visual_encoder: false
    num_heldout_frames: 0
    visual_encoder:
      type: eva_vit_g
      img_size: 224
      pretrained: false
      use_fp8: false
      transformer_engine: false

dataset:
  test_dataset:
    dataset_type: msrvtt
    mp4_urls: /data/video/*.mp4
    metadata: /data/test.json
    num_video_frames: 8
    resolution: [224, 224]
    batch_size: 8
    workers: 4
    split: null
    random_caption: false
    skip_missing_files: false
    caption_to_label:
__CAPTION_TO_LABEL__
